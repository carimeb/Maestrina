{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/carimeb/Maestrina/main/schema/maestrina_output.schema.json",
  "title": "Maestrina Output Contract",
  "$comment": "v2.1.0 adds the per-cluster 'sharding' block. The metadata-only approach for collecting sharded-cluster distribution through mongos is credited to Felipe Scabral's msizer-mongodb (https://github.com/felipesscabral/msizer-mongodb, getMongoSizingData_0.12.js).",
  "description": "Contract for the JSON file produced by either Maestrina collector (maestrina_collect.js via mongosh, or atlas_healthcheck.py via Atlas Admin API) and consumed by dashboard.html. Design rules: (1) both collectors emit the SAME structure; sections a mode cannot collect are present with available=false and data=null, so the dashboard can render gaps explicitly instead of hiding them; (2) only operational metadata and statistics are ever collected — no business data, no document contents, no query predicate values, no PII; (3) the file must be safe for a client security team to inspect before sending; (4) the collector never requires editing the script file itself (credentials come from the environment or interactive prompt), so the executed file can be hash-verified against the published version.",
  "type": "object",
  "required": [
    "maestrina",
    "compliance_manifest",
    "target",
    "baseline",
    "clusters",
    "errors"
  ],
  "additionalProperties": false,
  "properties": {
    "maestrina": {
      "type": "object",
      "description": "Provenance metadata: which collector produced this file, in which mode, when, and over what window.",
      "required": [
        "schema_version",
        "collector",
        "collection_mode",
        "generated_at",
        "collection_window"
      ],
      "additionalProperties": false,
      "properties": {
        "schema_version": {
          "type": "string",
          "pattern": "^2\\.[0-9]+\\.[0-9]+$",
          "description": "Semver of this contract. The dashboard refuses files with a major version it does not understand."
        },
        "collector": {
          "type": "object",
          "required": [
            "name",
            "version"
          ],
          "additionalProperties": false,
          "properties": {
            "name": {
              "type": "string",
              "enum": [
                "maestrina_collect.js",
                "atlas_healthcheck.py"
              ]
            },
            "version": {
              "type": "string",
              "description": "Version of the collector script that produced this file."
            }
          }
        },
        "collection_mode": {
          "type": "string",
          "enum": [
            "mongosh",
            "atlas_api"
          ],
          "description": "mongosh = low-friction mode, run by the client DBA with a database-admin user against the cluster; atlas_api = full mode, requires a read-only Atlas Admin API key. Determines which sections can be available."
        },
        "generated_at": {
          "type": "string",
          "format": "date-time",
          "description": "UTC timestamp when the file was written."
        },
        "collection_window": {
          "type": "object",
          "description": "What time span the numbers represent. In atlas_api mode this is the historical metrics window (typically 30 days). In mongosh mode counters are cumulative since process start, optionally refined by an in-run double sample.",
          "required": [
            "start",
            "end"
          ],
          "additionalProperties": false,
          "properties": {
            "start": {
              "type": "string",
              "format": "date-time"
            },
            "end": {
              "type": "string",
              "format": "date-time"
            },
            "second_sample_offset_seconds": {
              "type": [
                "integer",
                "null"
              ],
              "description": "mongosh mode only: seconds between the two in-run samples used to compute real ops/s deltas. Null in atlas_api mode."
            },
            "server_uptime_seconds": {
              "type": [
                "integer",
                "null"
              ],
              "description": "mongosh mode only: mongod uptime at collection time. Cumulative counters reset on restart/failover — the dashboard must caveat uptime-averaged rates when uptime is short."
            }
          }
        }
      }
    },
    "compliance_manifest": {
      "type": "object",
      "description": "Human-readable declaration of what this file does and does not contain, so the client's security team can review the output before it leaves their environment.",
      "required": [
        "statement",
        "categories_collected",
        "categories_excluded",
        "pseudonymization"
      ],
      "additionalProperties": false,
      "properties": {
        "statement": {
          "type": "string",
          "description": "Fixed sentence emitted by the collector, e.g.: 'This file contains only operational metadata and statistics (counters, sizes, rates, configuration flags). It contains no business data, no document contents, no query predicate values, and no personally identifiable information.'"
        },
        "categories_collected": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "server_status_counters",
              "replication_status",
              "storage_and_index_sizes",
              "index_usage_statistics",
              "connection_statistics",
              "cluster_configuration",
              "historical_metrics_series",
              "billing_by_sku_category",
              "backup_configuration",
              "alert_configuration",
              "performance_advisor_summaries"
            ]
          },
          "uniqueItems": true
        },
        "categories_excluded": {
          "type": "array",
          "description": "Always emitted in full, regardless of mode.",
          "items": {
            "type": "string"
          },
          "default": [
            "document_contents",
            "query_predicate_values",
            "user_accounts_and_credentials",
            "application_business_data",
            "personally_identifiable_information"
          ]
        },
        "pseudonymization": {
          "type": "object",
          "description": "Optional masking of object names (namespaces, hosts, index names). When enabled, the mapping is generated and retained client-side only; Maestrina never receives it.",
          "required": [
            "enabled"
          ],
          "additionalProperties": false,
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "method": {
              "type": [
                "string",
                "null"
              ],
              "enum": [
                "sha256_trunc8",
                "sequential_labels",
                null
              ],
              "description": "sha256_trunc8 = first 8 hex chars of SHA-256 of the name; sequential_labels = ns_001, host_A, etc."
            },
            "applies_to": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": [
                  "namespaces",
                  "hosts",
                  "index_names",
                  "database_names"
                ]
              },
              "uniqueItems": true
            }
          }
        }
      }
    },
    "target": {
      "type": "object",
      "description": "Identification of the deployment analyzed. Atlas-specific fields are null in mongosh mode when not inferable.",
      "required": [
        "cluster_name",
        "mongodb_version",
        "topology"
      ],
      "additionalProperties": false,
      "properties": {
        "cluster_name": {
          "type": "string",
          "description": "Cluster or replica-set name; may be a pseudonym if pseudonymization is enabled."
        },
        "mongodb_version": {
          "type": "string"
        },
        "topology": {
          "type": "string",
          "enum": [
            "replica_set",
            "sharded_cluster",
            "standalone"
          ]
        },
        "atlas": {
          "type": [
            "object",
            "null"
          ],
          "description": "Present in atlas_api mode; null in mongosh mode unless derivable from the connection.",
          "additionalProperties": false,
          "properties": {
            "project_id": {
              "type": [
                "string",
                "null"
              ]
            },
            "instance_tier": {
              "type": [
                "string",
                "null"
              ],
              "description": "e.g. M30"
            },
            "provider": {
              "type": [
                "string",
                "null"
              ],
              "description": "AWS | GCP | AZURE"
            },
            "region": {
              "type": [
                "string",
                "null"
              ]
            },
            "autoscaling_compute_enabled": {
              "type": [
                "boolean",
                "null"
              ]
            },
            "autoscaling_disk_enabled": {
              "type": [
                "boolean",
                "null"
              ]
            }
          }
        }
      }
    },
    "baseline": {
      "type": [
        "object",
        "null"
      ],
      "description": "Pre-go-live sizing band produced by the workload-fingerprinting playbook. Injected into the collector via a side file or CLI flag — never typed by the client. Null when no baseline exists (workload went to production without pre-sales sizing, which is precisely the population Maestrina targets). Feeds the realized-vs-forecast chart and turns post-go-live right-sizing into a planned milestone rather than a surprise.",
      "required": [
        "source",
        "created_at",
        "bands",
        "checkpoints"
      ],
      "additionalProperties": false,
      "properties": {
        "source": {
          "type": "string",
          "description": "Free text identifying the sizing exercise, e.g. 'workload-fingerprinting 2026-05'."
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        },
        "bands": {
          "type": "object",
          "description": "min–expected–max confidence bands from reference-class forecasting. All fields optional; include what the sizing produced.",
          "additionalProperties": false,
          "properties": {
            "monthly_cost_usd": {
              "$ref": "#/$defs/band"
            },
            "peak_ops_per_sec": {
              "$ref": "#/$defs/band"
            },
            "storage_gb": {
              "$ref": "#/$defs/band"
            },
            "working_set_gb": {
              "$ref": "#/$defs/band"
            }
          }
        },
        "assumptions": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Explicit assumptions the band depends on, restated so deviations can be attributed."
        },
        "checkpoints": {
          "type": "array",
          "description": "Contractualized calibration checkpoints (Pillar 2).",
          "items": {
            "type": "object",
            "required": [
              "day",
              "planned_date"
            ],
            "additionalProperties": false,
            "properties": {
              "day": {
                "type": "integer",
                "description": "Days after go-live: 30, 60, 90."
              },
              "planned_date": {
                "type": "string",
                "format": "date"
              },
              "completed": {
                "type": "boolean",
                "default": false
              }
            }
          }
        }
      }
    },
    "clusters": {
      "type": "array",
      "minItems": 1,
      "description": "One entry per cluster analyzed. mongosh mode always yields exactly one (the deployment the DBA connected to); atlas_api mode may yield several per project.",
      "items": {
        "type": "object",
        "required": [
          "name",
          "workload",
          "availability",
          "efficiency",
          "financial",
          "alert_hygiene",
          "sharding"
        ],
        "additionalProperties": false,
        "properties": {
          "name": {
            "type": "string"
          },
          "workload": {
            "allOf": [
              {
                "$ref": "#/$defs/section"
              }
            ],
            "description": "Measured rates and sizes — the same quantities the fingerprinting playbook measures pre-go-live, now realized. Available in BOTH modes.",
            "properties": {
              "available": {},
              "unavailable_reason": {},
              "data": {
                "type": [
                  "object",
                  "null"
                ],
                "additionalProperties": false,
                "properties": {
                  "rates": {
                    "type": "object",
                    "required": [
                      "method"
                    ],
                    "additionalProperties": false,
                    "properties": {
                      "method": {
                        "type": "string",
                        "enum": [
                          "two_sample_delta",
                          "uptime_average",
                          "atlas_30d_series"
                        ],
                        "description": "How ops/s was derived. two_sample_delta (mongosh, preferred) > atlas_30d_series (api) > uptime_average (mongosh fallback, weakest)."
                      },
                      "ops_per_sec": {
                        "type": "object",
                        "additionalProperties": false,
                        "properties": {
                          "insert": {
                            "type": [
                              "number",
                              "null"
                            ]
                          },
                          "query": {
                            "type": [
                              "number",
                              "null"
                            ]
                          },
                          "update": {
                            "type": [
                              "number",
                              "null"
                            ]
                          },
                          "delete": {
                            "type": [
                              "number",
                              "null"
                            ]
                          },
                          "getmore": {
                            "type": [
                              "number",
                              "null"
                            ]
                          },
                          "command": {
                            "type": [
                              "number",
                              "null"
                            ]
                          }
                        }
                      },
                      "read_write_ratio": {
                        "type": [
                          "number",
                          "null"
                        ]
                      }
                    }
                  },
                  "storage": {
                    "type": "object",
                    "additionalProperties": false,
                    "properties": {
                      "data_size_bytes": {
                        "type": [
                          "integer",
                          "null"
                        ]
                      },
                      "storage_size_bytes": {
                        "type": [
                          "integer",
                          "null"
                        ]
                      },
                      "index_size_bytes": {
                        "type": [
                          "integer",
                          "null"
                        ]
                      },
                      "growth_30d_percent": {
                        "type": [
                          "number",
                          "null"
                        ],
                        "description": "atlas_api mode: from disk metrics series. mongosh mode: null on first run; computable if a previous Maestrina JSON is supplied for delta."
                      }
                    }
                  },
                  "working_set_estimate_bytes": {
                    "type": [
                      "integer",
                      "null"
                    ],
                    "description": "Proxy from WiredTiger cache occupancy vs configured cache."
                  },
                  "top_namespaces": {
                    "type": "array",
                    "description": "Largest namespaces by total size. Names respect pseudonymization.",
                    "items": {
                      "type": "object",
                      "required": [
                        "namespace"
                      ],
                      "additionalProperties": false,
                      "properties": {
                        "namespace": {
                          "type": "string"
                        },
                        "data_size_bytes": {
                          "type": [
                            "integer",
                            "null"
                          ]
                        },
                        "index_size_bytes": {
                          "type": [
                            "integer",
                            "null"
                          ]
                        },
                        "document_count": {
                          "type": [
                            "integer",
                            "null"
                          ]
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "availability": {
            "allOf": [
              {
                "$ref": "#/$defs/section"
              }
            ],
            "description": "Downtime-risk axis inputs. Mostly available in both modes; elections/restarts counts and disk utilization require atlas_api.",
            "properties": {
              "available": {},
              "unavailable_reason": {},
              "data": {
                "type": [
                  "object",
                  "null"
                ],
                "additionalProperties": false,
                "properties": {
                  "replication": {
                    "type": "object",
                    "additionalProperties": false,
                    "properties": {
                      "max_lag_seconds": {
                        "type": [
                          "number",
                          "null"
                        ]
                      },
                      "members": {
                        "type": "array",
                        "items": {
                          "type": "object",
                          "required": [
                            "member",
                            "state"
                          ],
                          "additionalProperties": false,
                          "properties": {
                            "member": {
                              "type": "string",
                              "description": "Host or pseudonym."
                            },
                            "state": {
                              "type": "string",
                              "description": "PRIMARY | SECONDARY | ..."
                            },
                            "lag_seconds": {
                              "type": [
                                "number",
                                "null"
                              ]
                            }
                          }
                        }
                      }
                    }
                  },
                  "oplog_window_hours": {
                    "type": [
                      "number",
                      "null"
                    ]
                  },
                  "elections_last_30d": {
                    "type": [
                      "integer",
                      "null"
                    ],
                    "description": "atlas_api mode only (events API). Frequent primary elections signal instability."
                  },
                  "restarts_last_30d": {
                    "type": [
                      "integer",
                      "null"
                    ],
                    "description": "atlas_api mode only."
                  },
                  "tickets": {
                    "type": "object",
                    "additionalProperties": false,
                    "properties": {
                      "read_available": {
                        "type": [
                          "integer",
                          "null"
                        ]
                      },
                      "write_available": {
                        "type": [
                          "integer",
                          "null"
                        ]
                      }
                    }
                  },
                  "connections": {
                    "type": "object",
                    "additionalProperties": false,
                    "properties": {
                      "current": {
                        "type": [
                          "integer",
                          "null"
                        ]
                      },
                      "available": {
                        "type": [
                          "integer",
                          "null"
                        ]
                      },
                      "utilization_percent": {
                        "type": [
                          "number",
                          "null"
                        ]
                      }
                    }
                  },
                  "disk": {
                    "type": "object",
                    "additionalProperties": false,
                    "properties": {
                      "space_used_percent": {
                        "type": [
                          "number",
                          "null"
                        ]
                      },
                      "util_percent_max_30d": {
                        "type": [
                          "number",
                          "null"
                        ],
                        "description": "atlas_api mode only (hardware metrics series)."
                      }
                    }
                  },
                  "page_faults_per_sec": {
                    "type": [
                      "number",
                      "null"
                    ]
                  }
                }
              }
            }
          },
          "efficiency": {
            "allOf": [
              {
                "$ref": "#/$defs/section"
              }
            ],
            "description": "Churn/inefficiency axis. Global counters and index-usage stats work in both modes; Performance Advisor summaries require atlas_api. Dual output: each finding is a churn risk AND potentially an expansion signal (e.g. heavy $regex → Atlas Search).",
            "properties": {
              "available": {},
              "unavailable_reason": {},
              "data": {
                "type": [
                  "object",
                  "null"
                ],
                "additionalProperties": false,
                "properties": {
                  "query_targeting": {
                    "type": "object",
                    "additionalProperties": false,
                    "properties": {
                      "keys_scanned_per_returned": {
                        "type": [
                          "number",
                          "null"
                        ]
                      },
                      "objects_scanned_per_returned": {
                        "type": [
                          "number",
                          "null"
                        ]
                      },
                      "source": {
                        "type": [
                          "string",
                          "null"
                        ],
                        "enum": [
                          "server_status_global",
                          "atlas_metrics_30d",
                          null
                        ],
                        "description": "server_status_global = cluster-wide cumulative ratio; atlas_metrics_30d = time series max/avg."
                      }
                    }
                  },
                  "scan_and_order_per_sec": {
                    "type": [
                      "number",
                      "null"
                    ]
                  },
                  "cache": {
                    "type": "object",
                    "additionalProperties": false,
                    "properties": {
                      "configured_bytes": {
                        "type": [
                          "integer",
                          "null"
                        ]
                      },
                      "in_cache_bytes": {
                        "type": [
                          "integer",
                          "null"
                        ]
                      },
                      "dirty_percent": {
                        "type": [
                          "number",
                          "null"
                        ]
                      },
                      "fill_percent": {
                        "type": [
                          "number",
                          "null"
                        ]
                      }
                    }
                  },
                  "unused_indexes": {
                    "type": "array",
                    "description": "From $indexStats: indexes with zero (or near-zero) accesses since stats reset. Raw equivalent of Performance Advisor drop-index suggestions; works in mongosh mode.",
                    "items": {
                      "type": "object",
                      "required": [
                        "namespace",
                        "index"
                      ],
                      "additionalProperties": false,
                      "properties": {
                        "namespace": {
                          "type": "string"
                        },
                        "index": {
                          "type": "string"
                        },
                        "accesses_ops": {
                          "type": [
                            "integer",
                            "null"
                          ]
                        },
                        "accesses_since": {
                          "type": [
                            "string",
                            "null"
                          ],
                          "format": "date-time"
                        },
                        "size_bytes": {
                          "type": [
                            "integer",
                            "null"
                          ]
                        }
                      }
                    }
                  },
                  "performance_advisor": {
                    "type": [
                      "object",
                      "null"
                    ],
                    "description": "atlas_api mode only. Counts only — no query shapes are exported, to keep the file free of anything resembling application queries.",
                    "additionalProperties": false,
                    "properties": {
                      "suggested_indexes_count": {
                        "type": [
                          "integer",
                          "null"
                        ]
                      },
                      "drop_index_suggestions_count": {
                        "type": [
                          "integer",
                          "null"
                        ]
                      },
                      "schema_suggestions_count": {
                        "type": [
                          "integer",
                          "null"
                        ]
                      },
                      "data_platform_suggestions_count": {
                        "type": [
                          "integer",
                          "null"
                        ],
                        "description": "e.g. heavy $regex usage suggesting Atlas Search — expansion signal, not just risk."
                      }
                    }
                  }
                }
              }
            }
          },
          "financial": {
            "allOf": [
              {
                "$ref": "#/$defs/section"
              }
            ],
            "description": "Financial-risk axis. atlas_api mode ONLY: billing by SKU category plus 30-day series feeding the min–expected–max cost forecast. In mongosh mode: available=false, unavailable_reason='requires atlas_api mode (read-only API key)'.",
            "properties": {
              "available": {},
              "unavailable_reason": {},
              "data": {
                "type": [
                  "object",
                  "null"
                ],
                "additionalProperties": false,
                "properties": {
                  "billing_month_to_date": {
                    "type": "object",
                    "additionalProperties": false,
                    "properties": {
                      "total_usd": {
                        "type": [
                          "number",
                          "null"
                        ]
                      },
                      "by_sku_category": {
                        "type": "object",
                        "additionalProperties": false,
                        "properties": {
                          "compute_usd": {
                            "type": [
                              "number",
                              "null"
                            ]
                          },
                          "storage_usd": {
                            "type": [
                              "number",
                              "null"
                            ]
                          },
                          "backup_usd": {
                            "type": [
                              "number",
                              "null"
                            ]
                          },
                          "data_transfer_usd": {
                            "type": [
                              "number",
                              "null"
                            ]
                          },
                          "other_usd": {
                            "type": [
                              "number",
                              "null"
                            ]
                          }
                        }
                      }
                    }
                  },
                  "backup_to_compute_ratio_percent": {
                    "type": [
                      "number",
                      "null"
                    ],
                    "description": "Backup cost as % of compute cost. Thresholds in dashboard.html are Maestrina's own heuristics (no public MongoDB doc defines this ratio)."
                  },
                  "series": {
                    "type": "array",
                    "description": "Historical series for regression-based forecast bands.",
                    "items": {
                      "type": "object",
                      "required": [
                        "metric",
                        "unit",
                        "granularity",
                        "points"
                      ],
                      "additionalProperties": false,
                      "properties": {
                        "metric": {
                          "type": "string",
                          "description": "e.g. cpu_percent, ops_total, disk_used_gb, cost_daily_usd"
                        },
                        "unit": {
                          "type": "string"
                        },
                        "granularity": {
                          "type": "string",
                          "description": "ISO 8601 duration, e.g. PT1H, P1D"
                        },
                        "points": {
                          "type": "array",
                          "items": {
                            "type": "array",
                            "prefixItems": [
                              {
                                "type": "string",
                                "format": "date-time"
                              },
                              {
                                "type": [
                                  "number",
                                  "null"
                                ]
                              }
                            ],
                            "minItems": 2,
                            "maxItems": 2
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "alert_hygiene": {
            "allOf": [
              {
                "$ref": "#/$defs/section"
              }
            ],
            "description": "atlas_api mode ONLY: configured project alerts vs the recommended set (per MongoDB public documentation). In mongosh mode: available=false.",
